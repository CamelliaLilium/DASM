# === Training artifacts (regenerated by experiments) ===
# NOTE: Do NOT ignore paper evidence directories (figures/, tsne_results/, etc.)
# Those contain frozen reference outputs for the paper.

# === Worktrees (auto-worker) ===
.worktrees/

# === Sisyphus internal ===
# .sisyphus/ is kept for plan tracking

# =============================================================================
# IMPORTANT: The following directories contain PAPER EVIDENCE and MUST NOT be
# ignored. They hold static reference outputs (PNG, PDF, CSV, JSON) that
# correspond to tables and figures in the published paper.
#
#   figures/                  - Paper figures (loss landscape, t-SNE, heatmaps)
#   tsne_results/             - t-SNE visualization outputs
#   domain_gap_results/       - PAD analysis heatmaps and data
#   sharpness_analysis/       - Sharpness metrics tables
#   table_confident_level/    - Confidence interval statistics
#   performance/              - Benchmark comparison results
#
# ALSO PROTECTED (runtime assets, not generated outputs):
#   models_collection/wordTable/*.pth  - FS-MDP word lookup tables
# =============================================================================

# Ignore large generated files within evidence directories (but keep the directories for static evidence)
tsne_results/**/*.npz
domain_gap_results/**/*.pth
domain_gap_results/**/*.pth.tar
table_confident_level/**/*.pth.tar
sharpness_analysis/**/*.npz
performance/**/*.npz

# === Large data files (to be omitted from repo, documented elsewhere) ===
dataset/
dataset.zip
models_collection/*/model_best_*.pth.tar
table_confident_level/best_weight_confident/*.pth.tar
optimizers_collection/*/*.pth
optimizers_collection/*/*.pth.tar
performance/*.npz
sharpness_analysis/*.npz
.sisyphus/
dataset.zip
